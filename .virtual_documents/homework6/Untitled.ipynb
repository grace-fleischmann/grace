    [11, 13, 17],
    [7, 10, 13]
])
def is_prime(n):
    if n<2:
        return False 
    for i in range(2,n):
        if n % i == 0:
            return False 
    return True 
def alien_star(array): 
    result = []
    for row in array:
        for num in row: 
                if is_prime(num):
                    result.append(row)
                    break
        return np.array(result)
    
print(alien_star(arr))



